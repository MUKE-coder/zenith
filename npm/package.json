{
  "name": "zenith-analytics",
  "version": "0.1.0",
  "description": "Privacy-first analytics for your site — cookieless tracking and a dashboard that lives on your own domain.",
  "license": "MIT",
  "type": "module",
  "files": [
    "dist"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "import": "./dist/client.js",
      "require": "./dist/client.cjs"
    },
    "./next": {
      "types": "./dist/next.d.ts",
      "import": "./dist/next.js",
      "require": "./dist/next.cjs"
    }
  },
  "bin": {
    "zenith": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "node --test dist-test/*.test.js",
    "pretest": "tsc -p tsconfig.test.json"
  },
  "keywords": [
    "analytics",
    "privacy",
    "cookieless",
    "seo",
    "nextjs"
  ],
  "dependencies": {
    "bcryptjs": "^3.0.3"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "tsup": "^8.5.0",
    "typescript": "^5.9.3"
  }
}
